# =====================================================
# Penny NotebookLM Research — Cấu hình API Keys
# =====================================================
# Copy file này thành .env rồi điền API keys của bạn
# cp .env.example .env

# --- BRAVE SEARCH API (BẮT BUỘC cho tìm kiếm) ---
# Đăng ký miễn phí tại: https://brave.com/search/api/
# Free tier: 2,000 queries/tháng
BRAVE_API_KEY=your_brave_api_key_here

# --- APIFY TOKEN (tùy chọn — cho scraping chi tiết hơn) ---
# Đăng ký tại: https://www.apify.com?fpr=get-api
# Free tier: $5 credit/tháng, đủ cho ~500 video scrapes
APIFY_TOKEN=your_apify_token_here

# --- CẤU HÌNH MCP SERVER ---
# Chế độ transport: stdio (cho Claude Code) hoặc http (cho web UI)
NOTEBOOKLM_TRANSPORT=stdio

# Port cho HTTP mode (mặc định 3000)
NOTEBOOKLM_PORT=3000

# Port cho Web UI (mặc định 3333)
WEB_PORT=3333

# --- CẤU HÌNH TRÌNH DUYỆT ---
# Chạy Chrome ẩn (true) hoặc hiện (false)
HEADLESS=true

# Số session đồng thời tối đa
MAX_SESSIONS=5

# Timeout session (giây)
SESSION_TIMEOUT=900
